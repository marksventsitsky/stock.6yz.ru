# Server
PORT=8788
PUBLIC_BASE_URL=https://stock.6yz.ru
DB_PATH=data.sqlite

# Bitrix24 OAuth (local application, needed for refresh flow + admin auth check)
B24_CLIENT_ID=
B24_CLIENT_SECRET=
B24_REDIRECT_URI=https://stock.6yz.ru/b24/oauth/callback

# Protects /api/b24/setup endpoint (registers fields on the portal)
SETUP_SECRET=change-me

# Optional: fallback shared-secret admin access when not opened from inside Bitrix24
ADMIN_SECRET=change-me-too

# Field codes (Bitrix uses the same UF_CRM_ namespace for deals and leads,
# so one set of codes applies to both entities). Override only if Bitrix assigned different ones.
PROMO_JSON_FIELD=UF_CRM_PROMO_JSON
PROMO_CITY_FIELD=UF_CRM_PROMO_CITY
PROMO_BRAND_FIELD=UF_CRM_PROMO_BRAND
PROMO_TYPE_FIELD=UF_CRM_PROMO_TYPE
PROMO_NAME_FIELD=UF_CRM_PROMO_NAME
